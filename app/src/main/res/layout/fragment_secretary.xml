<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Icon -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:cardCornerRadius="60dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/green_100"
        app:strokeWidth="1dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="30dp"
            android:src="@drawable/ic_secretary"
            app:tint="@color/green_500" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="sans-serif-black"
        android:text="Secretary Portal"
        android:textColor="@color/gray_900"
        android:textSize="26sp" />

    <!-- Secretary name + section -->
    <TextView
        android:id="@+id/tv_secretary_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text=""
        android:textColor="@color/gray_500"
        android:textSize="14sp" />

    <!-- Current active class label -->
    <TextView
        android:id="@+id/tv_current_class"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Checking schedule…"
        android:textColor="@color/green_700"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Scan button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_scan_qr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/green_500"
        android:text="Scan Student QR"
        android:textColor="@android:color/white" />

    <!-- Scan result -->
    <TextView
        android:id="@+id/tv_scan_result"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="No scan yet"
        android:textColor="@color/gray_700"
        android:textSize="15sp" />

    <!-- Logout -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_logout_secretary"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Switch Role / Log Out"
        android:textColor="@color/gray_400"
        app:rippleColor="@color/gray_200" />

</LinearLayout>