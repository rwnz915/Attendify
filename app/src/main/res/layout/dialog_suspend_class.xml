<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Suspend This Class?"
        android:textColor="@color/gray_900"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <!-- Subject label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Subject"
        android:textColor="@color/gray_500"
        android:textSize="12sp" />

    <!-- Subject value -->
    <TextView
        android:id="@+id/dialog_subject_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/gray_900"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="14dp" />

    <!-- Section label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Section"
        android:textColor="@color/gray_500"
        android:textSize="12sp" />

    <!-- Section value -->
    <TextView
        android:id="@+id/dialog_section"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/gray_900"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="14dp" />

    <!-- Schedule label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Schedule"
        android:textColor="@color/gray_500"
        android:textSize="12sp" />

    <!-- Schedule value -->
    <TextView
        android:id="@+id/dialog_schedule"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/gray_900"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <!-- Warning notice -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This session will be marked as suspended today. No attendance will be recorded."
        android:textColor="@color/gray_700"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <!-- Yes, Suspend button -->
    <TextView
        android:id="@+id/dialog_btn_suspend"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center"
        android:text="Yes, Suspend"
        android:textColor="#FF6B00"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_suspend"
        android:layout_marginBottom="8dp" />

    <!-- Cancel button -->
    <TextView
        android:id="@+id/dialog_btn_cancel"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center"
        android:text="Cancel"
        android:textColor="@color/gray_700"
        android:textSize="15sp"
        android:background="@drawable/bg_btn_cancel" />

</LinearLayout>