<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_setup_page3_theme.xml
    Setup flow – Page 3 (NEW): Choose Your Theme
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    android:scrollbars="none"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="64dp"
        android:paddingBottom="40dp"
        android:gravity="center_horizontal">

        <!-- ── Icon circle ──────────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/iv_page_icon_container"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_setup_icon_blue_light"
            android:gravity="center">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/settings"
                android:tint="@color/white" />
        </FrameLayout>

        <!-- ── Headline ──────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tv_page_headline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Choose Your Theme"
            android:textColor="@color/gray_900"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_page_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Personalize your experience with a color\nscheme that suits you"
            android:textColor="@color/gray_500"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="2dp" />

        <!-- ── Role default badge ──────────────────────────────────── -->
        <TextView
            android:id="@+id/tv_role_default_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_badge_gray_pill"
            android:text="Default for your role"
            android:textColor="@color/gray_600"
            android:textSize="12sp" />

        <!-- ── Theme list ─────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/ll_theme_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical" />

        <!-- ── CTA Button ─────────────────────────────────────────── -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_apply_theme"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_setup_button"
            android:text="Apply Theme"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="2dp"
            android:stateListAnimator="@null" />

        <!-- ── Page dots ─────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/ll_dots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>