<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical">

    <!-- ── Header ──────────────────────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/about_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue_600"
        android:paddingStart="24dp"
        android:paddingTop="26dp"
        android:paddingEnd="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="14dp"
            android:text="About"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="10dp"
            android:contentDescription="Back"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white" />
    </FrameLayout>

    <!-- ── Scrollable body ─────────────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ══ App identity card ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingTop="36dp"
                android:paddingEnd="32dp"
                android:paddingBottom="28dp">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:contentDescription="Attendify Logo"
                    android:src="@drawable/logo" />

                <TextView
                    android:id="@+id/tv_app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Attendify"
                    android:textColor="@color/blue_600"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Version 1.0.0"
                    android:textColor="@color/gray_400"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:text="Smart attendance management system using geofencing and QR codes for schools. Built with modern technology for reliable, automated tracking."
                    android:textColor="@color/gray_600"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ══ Section label: Features ═══════════════════════════════════ -->
            <TextView
                android:tag="section_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="8dp"
                android:text="FEATURES"
                android:textColor="@color/blue_600"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- ══ Features card ══════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/card_rounded"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- GPS Geofencing -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:tag="icon_circle"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_blue_light"
                        android:contentDescription="GPS"
                        android:padding="8dp"
                        android:src="@drawable/ic_location"
                        app:tint="@color/blue_600" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GPS Geofencing"
                            android:textColor="@color/gray_800"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Auto check-in when you enter school campus"
                            android:textColor="@color/gray_500"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="66dp"
                    android:background="@color/gray_100" />

                <!-- QR Code -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:tag="icon_circle"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_blue_light"
                        android:contentDescription="QR"
                        android:padding="8dp"
                        android:src="@drawable/ic_qr_code"
                        app:tint="@color/blue_600" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="QR Code Scanning"
                            android:textColor="@color/gray_800"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Quick attendance verification via QR scan"
                            android:textColor="@color/gray_500"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="66dp"
                    android:background="@color/gray_100" />

                <!-- Offline Support -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:tag="icon_circle"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_blue_light"
                        android:contentDescription="Offline"
                        android:padding="8dp"
                        android:src="@drawable/ic_offline"
                        app:tint="@color/blue_600" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Offline Support"
                            android:textColor="@color/gray_800"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Records sync automatically when back online"
                            android:textColor="@color/gray_500"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="66dp"
                    android:background="@color/gray_100" />

                <!-- Secure & Private -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:tag="icon_circle"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_blue_light"
                        android:contentDescription="Secure"
                        android:padding="8dp"
                        android:src="@drawable/ic_security"
                        app:tint="@color/blue_600" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Secure &amp; Private"
                            android:textColor="@color/gray_800"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Firebase-backed encryption keeps your data safe"
                            android:textColor="@color/gray_500"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ Section label: Legal ═══════════════════════════════════════ -->
            <TextView
                android:tag="section_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="8dp"
                android:text="LEGAL"
                android:textColor="@color/blue_600"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- ══ Legal card ═════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/card_rounded"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Privacy Policy -->
                <LinearLayout
                    android:id="@+id/row_privacy_policy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:tag="icon_circle"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_blue_light"
                        android:contentDescription="Privacy"
                        android:padding="8dp"
                        android:src="@drawable/ic_privacy"
                        app:tint="@color/blue_600" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Privacy Policy"
                            android:textColor="@color/gray_800"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="How we collect, use and protect your data"
                            android:textColor="@color/gray_500"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Open"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/gray_400" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="66dp"
                    android:background="@color/gray_100" />

                <!-- Terms of Service -->
                <LinearLayout
                    android:id="@+id/row_terms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:tag="icon_circle"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_blue_light"
                        android:contentDescription="Terms"
                        android:padding="8dp"
                        android:src="@drawable/ic_description"
                        app:tint="@color/blue_600" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Terms of Service"
                            android:textColor="@color/gray_800"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Rules and conditions for using Attendify"
                            android:textColor="@color/gray_500"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Open"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/gray_400" />
                </LinearLayout>
            </LinearLayout>

            <!-- ══ Section label: Help & Support ═════════════════════════════ -->
            <TextView
                android:tag="section_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="8dp"
                android:text="HELP &amp; SUPPORT"
                android:textColor="@color/blue_600"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- ══ Support card ═══════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/card_rounded"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Email -->
                <LinearLayout
                    android:id="@+id/row_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:tag="icon_circle"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_blue_light"
                        android:contentDescription="Email"
                        android:padding="8dp"
                        android:src="@drawable/ic_email"
                        app:tint="@color/blue_600" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email Support"
                            android:textColor="@color/gray_800"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_support_contact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="presentime.attendify@gmail.com"
                            android:textColor="@color/blue_600"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="We\'ll respond within 24 hours"
                            android:textColor="@color/gray_400"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Open"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/gray_400" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="66dp"
                    android:background="@color/gray_100" />

                <!-- Phone -->
                <LinearLayout
                    android:id="@+id/row_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:tag="icon_circle"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_blue_light"
                        android:contentDescription="Phone"
                        android:padding="8dp"
                        android:src="@drawable/ic_phone"
                        app:tint="@color/blue_600" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phone Support"
                            android:textColor="@color/gray_800"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_phone_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="+63 956 654 0246"
                            android:textColor="@color/blue_600"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="Mon – Fri, 9am to 6pm"
                            android:textColor="@color/gray_400"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Open"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/gray_400" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="66dp"
                    android:background="@color/gray_100" />

                <!-- Facebook -->
                <LinearLayout
                    android:id="@+id/row_facebook"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:tag="icon_circle"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_blue_light"
                        android:contentDescription="Facebook"
                        android:padding="8dp"
                        android:src="@drawable/ic_facebook"
                        app:tint="@color/blue_600" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Facebook Page"
                            android:textColor="@color/gray_800"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_facebook_page"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="facebook.com/presentime"
                            android:textColor="@color/blue_600"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="Message us on our official page"
                            android:textColor="@color/gray_400"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Open"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/gray_400" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="66dp"
                    android:background="@color/gray_100" />

                <!-- Location (non-tappable) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:tag="icon_circle"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_blue_light"
                        android:contentDescription="Location"
                        android:padding="8dp"
                        android:src="@drawable/ic_location"
                        app:tint="@color/blue_600" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textColor="@color/gray_800"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Quezon City, Philippines"
                            android:textColor="@color/gray_500"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ Footer ═════════════════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:text="© 2026 Attendify. All rights reserved."
                android:textColor="@color/gray_400"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="Made with dedication for better education."
                android:textColor="@color/gray_400"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>