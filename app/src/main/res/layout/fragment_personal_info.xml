<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/personal_info_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingTop="56dp"
        android:paddingEnd="24dp"
        android:background="@color/blue_600">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Personal Information"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:layout_marginBottom="10dp"
            android:textStyle="bold" />
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="8dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white"
            android:layout_marginBottom="10dp"
            android:contentDescription="Back" />
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="@color/gray_500"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_full_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Lastname, Firstname"
                android:textColor="@color/gray_800"
                android:textSize="16sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginTop="16dp" android:layout_marginBottom="16dp"
                android:background="@color/gray_200" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textColor="@color/gray_500"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="email@example.com"
                android:textColor="@color/gray_800"
                android:textSize="16sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginTop="16dp" android:layout_marginBottom="16dp"
                android:background="@color/gray_200" />

            <!-- Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Section / Department"
                android:textColor="@color/gray_500"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="N/A"
                android:textColor="@color/gray_800"
                android:textSize="16sp" />

            <View android:id="@+id/divider_parent" android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginTop="16dp" android:layout_marginBottom="16dp"
                android:background="@color/gray_200" />

            <!-- Parent Info (Student Only) -->
            <LinearLayout
                android:id="@+id/layout_parent_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parent / Guardian"
                    android:textColor="@color/gray_500"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_parent_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Parent Name"
                    android:textColor="@color/gray_800"
                    android:textSize="16sp" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginTop="16dp" android:layout_marginBottom="16dp"
                    android:background="@color/gray_200" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parent Contact Number"
                    android:textColor="@color/gray_500"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_parent_contact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="09XXXXXXXXX"
                    android:textColor="@color/gray_800"
                    android:textSize="16sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
