<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tv_month_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="February 2026"
                android:textColor="@color/gray_800"
                android:textSize="17sp"
                android:textStyle="bold" />
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/gray_400" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_progress_bar"
            android:clipToOutline="true"
            android:orientation="horizontal">
            <View
                android:id="@+id/progress_present"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@color/green_500" />
            <View
                android:id="@+id/progress_late"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@color/yellow_500" />
            <View
                android:id="@+id/progress_absent"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@color/red_500" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_month_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="28 Present • 1 Late • 2 Absent"
                android:textColor="@color/gray_500"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
