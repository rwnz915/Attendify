<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    android:orientation="vertical">

    <!-- Themed Header (theme applied in Java) -->
    <LinearLayout
        android:id="@+id/teacher_qr_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="48dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <!-- Back arrow + title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_white_transparent"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/white"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Scan QR Code"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_qr_active_class"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="50dp"
            android:text="Checking schedule…"
            android:textColor="#CCFFFFff"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Scroll body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Scanner viewfinder card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <!-- QR frame icon -->
                    <FrameLayout
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:background="@color/gray_100">

                        <View android:id="@+id/qr_corner_tl_h"
                            android:layout_width="30dp" android:layout_height="4dp"
                            android:layout_gravity="top|start"
                            android:background="@color/blue_600" />
                        <View android:id="@+id/qr_corner_tl_v"
                            android:layout_width="4dp" android:layout_height="30dp"
                            android:layout_gravity="top|start"
                            android:background="@color/blue_600" />
                        <View android:id="@+id/qr_corner_tr_h"
                            android:layout_width="30dp" android:layout_height="4dp"
                            android:layout_gravity="top|end"
                            android:background="@color/blue_600" />
                        <View android:id="@+id/qr_corner_tr_v"
                            android:layout_width="4dp" android:layout_height="30dp"
                            android:layout_gravity="top|end"
                            android:background="@color/blue_600" />
                        <View android:id="@+id/qr_corner_bl_h"
                            android:layout_width="30dp" android:layout_height="4dp"
                            android:layout_gravity="bottom|start"
                            android:background="@color/blue_600" />
                        <View android:id="@+id/qr_corner_bl_v"
                            android:layout_width="4dp" android:layout_height="30dp"
                            android:layout_gravity="bottom|start"
                            android:background="@color/blue_600" />
                        <View android:id="@+id/qr_corner_br_h"
                            android:layout_width="30dp" android:layout_height="4dp"
                            android:layout_gravity="bottom|end"
                            android:background="@color/blue_600" />
                        <View android:id="@+id/qr_corner_br_v"
                            android:layout_width="4dp" android:layout_height="30dp"
                            android:layout_gravity="bottom|end"
                            android:background="@color/blue_600" />

                        <!-- Center QR icon -->
                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_gravity="center"
                            android:src="@drawable/qr_code"
                            android:tint="@color/gray_400" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Point camera at student's QR code"
                        android:textColor="@color/gray_500"
                        android:textSize="13sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Scan button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_scanner"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:text="Scan Student QR"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <!-- Result card (hidden until scan) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_scan_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_result_status_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅ PRESENT"
                        android:textColor="@color/green_700"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/gray_100" />

                    <TextView
                        android:id="@+id/tv_result_student_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/gray_800"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_result_subject"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/gray_500"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time: "
                            android:textColor="@color/gray_500"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_result_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gray_700"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Error / info message -->
            <TextView
                android:id="@+id/tv_qr_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text=""
                android:textColor="@color/gray_500"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>