<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- ── Header (fixed, outside ScrollView) ─────────────────────────────── -->
    <LinearLayout
        android:id="@+id/export_dialog_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="12dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Export Attendance"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configure period, filters, and file"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_close_dialog"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_close"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close" />
    </LinearLayout>

    <!-- ── Scrollable content ──────────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Period type ──────────────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Period Type"
                        android:textColor="@color/gray_800"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_period"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:chipSpacingHorizontal="6dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Date filters ─────────────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date Range"
                        android:textColor="@color/gray_800"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Month row -->
                    <LinearLayout
                        android:id="@+id/row_month"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="Month"
                            android:textColor="@color/gray_500"
                            android:textSize="12sp" />

                        <Spinner
                            android:id="@+id/spinner_export_month"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_filter_inactive"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp" />
                    </LinearLayout>

                    <!-- Day row (shown for Day type only) -->
                    <LinearLayout
                        android:id="@+id/row_day"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="Day"
                            android:textColor="@color/gray_500"
                            android:textSize="12sp" />

                        <Spinner
                            android:id="@+id/spinner_export_day"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_filter_inactive"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp" />
                    </LinearLayout>

                    <!-- Week row (shown for Weekly type only) -->
                    <LinearLayout
                        android:id="@+id/row_week"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="2dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="Week"
                            android:textColor="@color/gray_500"
                            android:textSize="12sp" />

                        <Spinner
                            android:id="@+id/spinner_export_week"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_filter_inactive"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Subject / Section filters ────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Filters"
                        android:textColor="@color/gray_800"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Subject -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="Subject"
                            android:textColor="@color/gray_500"
                            android:textSize="12sp" />

                        <Spinner
                            android:id="@+id/spinner_export_subject"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_filter_inactive"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp" />
                    </LinearLayout>

                    <!-- Section (hidden for Secretary) -->
                    <LinearLayout
                        android:id="@+id/row_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="2dp">

                        <TextView
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="Section"
                            android:textColor="@color/gray_500"
                            android:textSize="12sp" />

                        <Spinner
                            android:id="@+id/spinner_export_section"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_filter_inactive"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Upload / Format option ────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upload Format"
                        android:textColor="@color/gray_800"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <!-- Format selector chips -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_format"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:chipSpacingHorizontal="6dp"
                        android:layout_marginBottom="4dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_format_default"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Default Export"
                            android:checkable="true"
                            android:checked="true"
                            style="@style/Widget.MaterialComponents.Chip.Choice" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_format_own"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Own Format"
                            android:checkable="true"
                            style="@style/Widget.MaterialComponents.Chip.Choice" />

                    </com.google.android.material.chip.ChipGroup>

                    <!-- Upload section — hidden by default, shown when "Own Format" is selected -->
                    <LinearLayout
                        android:id="@+id/layout_upload_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Upload your own CSV or PDF (e.g. the weekly monitoring sheet)"
                            android:textColor="@color/gray_500"
                            android:textSize="11sp" />

                        <!-- File name + clear row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_document"
                                android:tint="@color/gray_400" />

                            <TextView
                                android:id="@+id/tv_file_name"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                android:text="No file selected"
                                android:textColor="@color/gray_500"
                                android:textSize="12sp"
                                android:singleLine="true"
                                android:ellipsize="middle" />

                            <ImageView
                                android:id="@+id/iv_clear_import"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_close"
                                android:tint="@color/gray_400"
                                android:padding="2dp"
                                android:visibility="gone"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Clear import" />
                        </LinearLayout>

                        <!-- Status message -->
                        <TextView
                            android:id="@+id/tv_import_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:textSize="12sp"
                            android:visibility="gone" />

                        <!-- Progress -->
                        <ProgressBar
                            android:id="@+id/progress_export"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:indeterminate="true"
                            android:layout_marginBottom="10dp"
                            android:visibility="gone" />

                        <!-- Upload button -->
                        <Button
                            android:id="@+id/btn_import_file"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="Choose File (CSV / PDF)"
                            android:textSize="13sp"
                            android:textColor="@color/blue_600"
                            android:backgroundTint="@color/blue_50"
                            style="?attr/materialButtonOutlinedStyle"
                            android:strokeColor="@color/blue_100" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Action buttons ────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingEnd="16dp"
                android:paddingBottom="28dp">

                <Button
                    android:id="@+id/btn_export_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Export to CSV"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/blue_600"
                    android:layout_marginBottom="10dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>