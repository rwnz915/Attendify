<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical">

    <!-- Header -->
    <FrameLayout
        android:id="@+id/security_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingTop="56dp"
        android:paddingEnd="24dp"
        android:background="@color/blue_600">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Privacy &amp; Security"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:layout_marginBottom="10dp"
            android:textStyle="bold" />
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="10dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_icon_white_transparent"
            app:tint="@color/white"
            android:contentDescription="Back" />
    </FrameLayout>

    <!-- Password Card -->
    <LinearLayout
        android:id="@+id/card_change_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:background="@drawable/bg_card"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:clickable="true"
        android:focusable="true">

        <!-- Lock icon circle -->
        <ImageView
            android:id="@+id/iv_password_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_lock"
            android:contentDescription="Password" />

        <!-- Text block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change Password"
                android:textColor="@color/gray_800"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Update your account password"
                android:textColor="@color/gray_500"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Chevron arrow -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_back"
            android:rotation="180"
            android:alpha="0.4"
            android:contentDescription="Open" />

    </LinearLayout>

</LinearLayout>